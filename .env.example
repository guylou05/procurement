# ── Application ────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000

# ── Auth.js ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-in-production
AUTH_TRUST_HOST=true

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
DATABASE_URL=postgresql://buildflow:buildflow@localhost:5432/buildflow?schema=public

# ── Object storage (S3 / Cloudflare R2 / MinIO) ────────────────────────────
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=buildflow
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_URL=http://localhost:9000/buildflow

# ── Email (transactional) ──────────────────────────────────────────────────
# MVP logs emails to console when unset; wire an SMTP/provider later.
EMAIL_FROM=no-reply@buildflow.africa
SMTP_URL=

# ── Feature flags (future modules) ─────────────────────────────────────────
FEATURE_BILLING=false
FEATURE_MOBILE_MONEY=false
