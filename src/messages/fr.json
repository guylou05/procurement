    },
    "featuresTitle": "Tout ce dont vos équipes de terrain ont besoin, au même endroit",
    "featuresSubtitle": "Remplacez les fils WhatsApp dispersés, les carnets papier et les fichiers Excel par un seul système visible par toute l'entreprise.",
    "features": {
      "dailyReports": { "title": "Rapports journaliers de chantier", "desc": "Les chefs de chantier consignent les travaux réalisés, les matériaux utilisés et les incidents en moins de trois minutes, depuis n'importe quel téléphone." },
      "attendance": { "title": "Présence et main-d'œuvre", "desc": "Pointage rapide par ouvrier avec GPS et corrections auditées, pour des coûts de main-d'œuvre toujours exacts." },
      "projects": { "title": "Projets et budgets", "desc": "Suivez en temps réel le statut, le budget, les jalons et l'avancement de chaque chantier." },
      "materials": { "title": "Matériaux et inventaire", "desc": "Alertes de stock faible et workflow complet de demande à approbation pour que les chantiers ne manquent de rien." },
      "expenses": { "title": "Dépenses et approbations", "desc": "Les dépenses de terrain sont automatiquement routées vers le bon approbateur, avec des seuils d'approbation automatique configurables." },
      "equipment": { "title": "Suivi des équipements", "desc": "Sachez où se trouve chaque équipement, qui l'utilise, et quand la prochaine maintenance est due." },
      "portal": { "title": "Portail client", "desc": "Offrez à vos clients une vue claire de l'avancement, des jalons et des factures — sans exposer les coûts ou marges internes." },
      "team": { "title": "Rôles et permissions", "desc": "Propriétaires, chefs de projet, chefs de chantier, comptables et ouvriers voient chacun exactement ce dont ils ont besoin." }
    },
    "howItWorksTitle": "De l'inscription à votre premier rapport de chantier en quelques minutes",
    "howItWorksSubtitle": "Pas de projet d'implémentation, pas de formation — juste une configuration simple que votre équipe peut utiliser dès aujourd'hui.",
    "steps": {
      "one": { "title": "Créez votre entreprise", "desc": "Définissez votre pays, votre devise et votre langue. L'anglais et le français sont tous deux natifs dès le premier jour." },
      "two": { "title": "Ajoutez des projets et invitez votre équipe", "desc": "Créez votre premier chantier, invitez chefs de chantier et ouvriers, et attribuez les rôles en quelques minutes." },
      "three": { "title": "Gérez les opérations quotidiennes", "desc": "Présence, rapports journaliers, matériaux et dépenses — saisis depuis le terrain, sur n'importe quel téléphone." },
      "four": { "title": "Visualisez tout depuis le tableau de bord", "desc": "La direction obtient une visibilité en temps réel sur chaque chantier, chaque coût, chaque approbation — plus besoin de relancer." }
    },
    "marketsTitle": "Conçu pour l'Afrique francophone et anglophone",
    "marketsSubtitle": "Devises locales, fuseaux horaires et français des affaires natifs — pas ajoutés après coup. Actuellement configuré pour ces marchés, avec d'autres à venir.",
    "faqTitle": "Questions fréquentes",
    "faq": {
      "q1": "BuildFlow est-il disponible en français ?",
      "a1": "Oui. L'anglais et le français sont tous deux entièrement pris en charge dès le premier écran — navigation, formulaires, notifications et rapports — et chaque membre de l'équipe peut choisir sa propre langue indépendamment de celle de l'entreprise.",
      "q2": "Quels pays sont pris en charge ?",
      "a2": "La plateforme est livrée avec des devises et fuseaux horaires par défaut pour les principaux marchés africains francophones et anglophones, et prend en charge la devise et le pays propres à chaque organisation.",
      "q3": "Fonctionne-t-il sur une connexion lente ?",
      "a3": "Oui. L'application est conçue mobile d'abord comme une Progressive Web App installable, avec des pages légères et l'enregistrement de brouillons sur les formulaires de terrain prioritaires, pour qu'une coupure de connexion ne fasse pas perdre votre travail.",
      "q4": "Les données de mon entreprise sont-elles isolées des autres entreprises ?",
      "a4": "Oui. Les données de chaque organisation sont isolées au niveau du serveur — l'accès est vérifié à chaque requête et jamais basé sur ce qu'envoie le navigateur, une entreprise ne peut donc jamais voir les données d'une autre.",
      "q5": "Puis-je contrôler ce que voient mes clients ?",
      "a5": "Oui. Les clients n'accèdent qu'à un portail dédié montrant l'avancement des projets partagés, les jalons et les factures — jamais les coûts internes, les taux de rémunération des ouvriers ou les marges."
    },
